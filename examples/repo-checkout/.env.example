# Copy this file to .env and fill in your token.
# Add .env to .gitignore — never commit it.
#
# Create a token at: https://github.com/settings/tokens
# Required scopes: Contents (Read) for cloning private repos.
# Add Pull requests (Read & Write) if the agent needs to open PRs.
#
# GH_TOKEN is the gh CLI's preferred name; GITHUB_TOKEN also works
# (it's what GitHub Actions uses). agv accepts either; if both are set,
# GH_TOKEN wins.

GH_TOKEN=ghp_...
